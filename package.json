{
  "name": "bsv-cuda-validator",
  "version": "1.0.0",
  "description": "CUDA-accelerated BSV block validation",
  "main": "dist/validator.js",
  "types": "dist/validator.d.ts",
  "scripts": {
    "build": "tsc && npm run build:native",
    "build:native": "node-gyp configure && node-gyp build",
    "build:cuda": "cd cuda && make",
    "test": "jest --testTimeout=30000",
    "start": "node dist/validator.js",
    "clean": "rimraf dist build cuda/*.o cuda/*.so",
    "sync": "export $(cat .env.sync | xargs) && rsync -avz --delete --exclude='node_modules' --exclude='.git' --exclude='logs' --exclude='data' . $REMOTE_USER@$REMOTE_HOST:$REMOTE_DIR",
    "sync:deploy": "export $(cat .env.sync | xargs) && npm run sync && ssh $REMOTE_USER@$REMOTE_HOST \"cd $REMOTE_DIR && docker compose up --build -d\"",
    "sync:check": "export $(cat .env.sync | xargs) && ssh $REMOTE_USER@$REMOTE_HOST \"cd $REMOTE_DIR && pwd && ls -la docker-compose.yml\""
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "nan": "^2.18.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "node-gyp": "^12.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
