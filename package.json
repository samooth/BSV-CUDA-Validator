{
  "name": "bsv-cuda-validator",
  "version": "1.0.0",
  "description": "CUDA-accelerated BSV block validation",
  "main": "dist/validator.js",
  "types": "dist/validator.d.ts",
  "scripts": {
    "build": "tsc && npm run build:native",
    "build:native": "node-gyp configure && node-gyp build",
    "build:cuda": "cd cuda && make",
    "test": "jest --testTimeout=30000",
    "start": "node dist/validator.js",
    "clean": "rimraf dist build cuda/*.o cuda/*.so",
    "sync": "export $(cat .env.sync | xargs) && rsync -avzc -e \"ssh -p $SSH_PORT\" --delete --exclude='node_modules' --exclude='.git' --exclude='logs' --exclude='data' . $REMOTE_USER@$REMOTE_HOST:$REMOTE_DIR",
    "sync:deploy": "export $(cat .env.sync | xargs) && npm run sync && ssh -p $SSH_PORT $REMOTE_USER@$REMOTE_HOST \"cd $REMOTE_DIR && docker compose up --build -d\"",
    "sync:check": "export $(cat .env.sync | xargs) && ssh -p $SSH_PORT $REMOTE_USER@$REMOTE_HOST \"cd $REMOTE_DIR && pwd && ls -la docker-compose.yml\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nan": "^2.26.1",
    "secp256k1": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.3.0",
    "node-gyp": "^12.2.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
