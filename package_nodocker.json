{
  "name": "bsv-cuda-validator",
  "version": "1.0.0",
  "description": "CUDA-accelerated BSV block validation for sovereign infrastructure",
  "main": "dist/validator.js",
  "types": "dist/validator.d.ts",
  "scripts": {
    "build": "tsc && npm run build:native",
    "build:native": "node-gyp rebuild",
    "build:cuda": "cd cuda && make",
    "test": "jest --testTimeout=30000",
    "test:gpu": "jest --testPathPattern=gpu --testTimeout=60000",
    "test:unit": "jest --testPathPattern=unit",
    "lint": "eslint src/**/*.ts",
    "start": "node dist/validator.js",
    "dev": "ts-node src/validator.ts",
    "clean": "rimraf dist build cuda/*.o cuda/*.so"
  },
  "keywords": [
    "bsv",
    "bitcoin",
    "cuda",
    "gpu",
    "blockchain",
    "validation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/node-gyp": "^9.3.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "node-gyp": "^10.0.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "gypfile": true,
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}